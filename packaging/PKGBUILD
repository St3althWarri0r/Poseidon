# Maintainer: local build — CachyOS/Arch native package for Poseidon
# Build & install:  cd packaging && makepkg -si
pkgname=poseidon
pkgver=2.5.0
pkgrel=1
pkgdesc="Autonomous AI trading platform with Claude as the portfolio manager"
arch=('any')
url="https://github.com/St3althWarri0r/Poseidon"
license=('MIT')
depends=('python' 'python-anthropic' 'python-httpx' 'python-pydantic'
         'python-pydantic-settings' 'python-yaml' 'python-structlog'
         'python-cryptography' 'python-aiosqlite' 'python-fastapi'
         'uvicorn' 'python-websockets' 'python-croniter' 'python-dateutil'
         'libnotify')
makedepends=('python-build' 'python-installer' 'python-hatchling')
source=()
sha256sums=()

pkgver() {
  cd "$startdir/.."
  python -c "import tomllib; print(tomllib.load(open('pyproject.toml', 'rb'))['project']['version'])"
}

build() {
  cd "$startdir/.."
  python -m build --wheel --no-isolation --outdir "$srcdir/dist"
}

package() {
  python -m installer --destdir="$pkgdir" "$srcdir"/dist/*.whl
  cd "$startdir/.."
  install -Dm644 packaging/poseidon.desktop \
    "$pkgdir/usr/share/applications/poseidon.desktop"
  install -Dm644 config/poseidon.example.yaml \
    "$pkgdir/usr/share/poseidon/poseidon.example.yaml"
  # The stock unit points at the venv install; the system package uses /usr/bin.
  sed 's|ExecStart=.*|ExecStart=/usr/bin/poseidon run|' packaging/poseidon.service \
    > "$srcdir/poseidon.service"
  install -Dm644 "$srcdir/poseidon.service" \
    "$pkgdir/usr/lib/systemd/user/poseidon.service"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
